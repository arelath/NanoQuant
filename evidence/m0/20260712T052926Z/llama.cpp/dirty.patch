+        const float xv = *(const float *) ((const char *) x + i*nbx0 + i1*nbx1 + i2*nbx2 + i3*nbx3);
+        acc = nanoquant_fmaf_sign_word(word, lane, xv, scale_pre[i], acc);
+    }
