+        acc1 = nanoquant_fmaf_sign_word(word1, lane, x1, scale_pre[i1_in], acc1);
+        acc2 = nanoquant_fmaf_sign_word(word2, lane, x2, scale_pre[i2_in], acc2);
+        acc3 = nanoquant_fmaf_sign_word(word3, lane, x3, scale_pre[i3_in], acc3);
