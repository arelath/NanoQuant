+        for (int64_t base = 0; base < n_in; base += WARP_SIZE) {
+            const int64_t i = base + lane;
+            uint32_t word = lane == 0 ? nanoquant_load_sign_word(v_bits, nbv0, nbv1, r, base/WARP_SIZE) : 0;
