+template <int block_size, int cols_per_block>
+static __global__ void nanoquant_stage1_fused_coltile_kernel(
+        const void * x,
+        const int64_t nbx0,
+        const int64_t nbx1,
+        const int64_t nbx2,
+        const int64_t nbx3,
+        const int32_t * v0,
