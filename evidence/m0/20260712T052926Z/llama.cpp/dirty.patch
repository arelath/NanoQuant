+    result->src[3] = scale_post0;
+    result->src[4] = salient_idx0;
+    result->src[5] = salient_weight0;
+    result->src[6] = u1;
+    result->src[7] = scale_post1;
+    result->src[8] = salient_idx1;
+    result->src[9] = salient_weight1;
+
+    return result;
+}
