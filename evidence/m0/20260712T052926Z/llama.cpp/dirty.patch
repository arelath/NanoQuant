+        const float x1 = *(const float *) ((const char *) x + i1_in*nbx0 + i1*nbx1 + i2*nbx2 + i3*nbx3);
+        const float x2 = *(const float *) ((const char *) x + i2_in*nbx0 + i1*nbx1 + i2*nbx2 + i3*nbx3);
